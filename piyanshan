                                            <img key={activeFeature} src={features[activeFeature].image} alt={features[activeFeature].title} className="w-full h-full object-cover animate-fadeIn" />
                                            <div className="absolute inset-0 bg-gradient-to-t from-gray-900/80 to-transparent"></div>
                                            <div className="absolute bottom-8 left-8 right-8">
                                                <h3 className="text-3xl font-bold text-white mb-4">{features[activeFeature].title}</h3>
                                                <div className="flex flex-wrap gap-2">
                                                    {features[activeFeature].tags.map((tag, idx) => (
                                                        <span key={idx} className="bg-white/20 backdrop-blur-md text-white px-3 py-1 rounded-full text-sm border border-white/30">{tag}</span>
                                                    ))}
                                                </div>
                                            </div>
                                        </div>
                                        <div className="p-8">
                                            <p className="text-gray-700 text-lg leading-relaxed mb-6">{features[activeFeature].desc}</p>
                                            <div className="flex flex-col sm:flex-row gap-4">
                                                <button onClick={() => setDetailFeature(features[activeFeature])} className="bg-emerald-50 text-emerald-700 px-6 py-3 rounded-full font-bold flex items-center justify-center gap-2 hover:bg-emerald-100 transition">
                                                    查看项目详情 <Icon name="Info" size={18} />
                                                </button>
                                                <button onClick={() => setBookingModalOpen(true)} className="text-emerald-600 font-bold flex items-center justify-center gap-2 hover:text-emerald-800 transition">
                                                    预订此体验套餐 <Icon name="ChevronRight" size={18} />
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    {/* Footer */}
                    <footer className="bg-gray-950 text-gray-400 py-16 border-t border-gray-900 mt-12">
                        <div className="max-w-7xl mx-auto px-4 text-center">
                            <p>© 2026 琵岩山生态文旅度假区. 保留所有权利.</p>
                        </div>
                    </footer>

                    {/* Booking Modal */}
                    {isBookingModalOpen && (
                        <div className="fixed inset-0 z-[100] flex items-center justify-center p-4">
                            <div className="absolute inset-0 bg-black/60 backdrop-blur-sm" onClick={() => setBookingModalOpen(false)}></div>
                            <div className="bg-white rounded-3xl w-full max-w-lg relative z-10 shadow-2xl p-6 animate-slideUp">
                                <h3 className="text-xl font-bold mb-6 flex items-center gap-2"><Icon name="Calendar" /> 在线预订行程</h3>
                                <form onSubmit={handleBookingSubmit} className="space-y-4">
                                    <input required type="text" className="w-full border rounded-xl px-4 py-3 bg-gray-50 focus:border-emerald-500 focus:outline-none" placeholder="您的姓名" />
                                    <input required type="tel" className="w-full border rounded-xl px-4 py-3 bg-gray-50 focus:border-emerald-500 focus:outline-none" placeholder="联系电话" />
                                    <input required type="date" className="w-full border rounded-xl px-4 py-3 bg-gray-50 focus:border-emerald-500 focus:outline-none" />
                                    <button type="submit" className="w-full bg-emerald-600 text-white rounded-xl py-3.5 font-bold hover:bg-emerald-700 mt-2">确认提交预订</button>
                                    <button type="button" onClick={() => setBookingModalOpen(false)} className="w-full text-gray-500 py-2">取消</button>
                                </form>
                            </div>
                        </div>
                    )}

                    {/* Feature Details Modal */}
                    {detailFeature && (
                        <div className="fixed inset-0 z-[110] flex items-center justify-center p-4 md:p-8">
                            <div className="absolute inset-0 bg-black/60 backdrop-blur-sm" onClick={() => setDetailFeature(null)}></div>
                            <div className="bg-white rounded-3xl w-full max-w-4xl max-h-[90vh] overflow-y-auto relative z-10 shadow-2xl animate-slideUp">
                                <button onClick={() => setDetailFeature(null)} className="absolute top-4 right-4 bg-black/50 text-white p-2 rounded-full z-20"><Icon name="X" size={24} /></button>
                                <div className="h-64 relative w-full">
                                    <img src={detailFeature.image} alt={detailFeature.title} className="w-full h-full object-cover" />
                                </div>
                                <div className="p-6 md:p-10">
                                    <h3 className="text-3xl font-bold mb-6">{detailFeature.title}</h3>
                                    <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                                        {detailFeature.details.map((item, idx) => (
                                            <div key={idx} className="bg-gray-50 p-4 rounded-xl border">
                                                <h5 className="font-bold text-emerald-800 mb-2">{item.title}</h5>
                                                <p className="text-sm text-gray-600">{item.content}</p>
                                            </div>
                                        ))}
                                    </div>
                                    <div className="flex justify-end gap-4">
                                        {detailFeature.title === "朝鲜族民俗村" && (
                                            <button onClick={() => { setDetailFeature(null); setAIAvatarModalOpen(true); }} className="px-8 py-3 bg-gradient-to-r from-purple-600 to-indigo-600 text-white rounded-full font-bold flex items-center gap-2">
                                                <Icon name="Wand2" size={18} /> 体验 AI 换装
                                            </button>
                                        )}
                                        <button onClick={() => { setDetailFeature(null); setBookingModalOpen(true); }} className="px-8 py-3 bg-emerald-600 text-white rounded-full font-bold">立即预订</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    )}

                    {/* Info Modal */}
                    {isInfoModalOpen && (
                        <div className="fixed inset-0 z-[100] flex items-center justify-center p-4">
                            <div className="absolute inset-0 bg-black/60 backdrop-blur-sm" onClick={() => setInfoModalOpen(false)}></div>
                            <div className="bg-white rounded-3xl w-full max-w-2xl relative z-10 shadow-2xl p-8 animate-slideUp">
                                <h3 className="text-2xl font-bold mb-4">关于琵岩山文旅项目</h3>
                                <p className="text-gray-600 mb-4 leading-relaxed">
                                    琵岩山“泉韵民俗·森野食光” 是一项集生态康养、民俗体验、森野美食于一体的综合性文旅产品开发方案。
                                    依托特有的高氟偏硅酸温泉和得天独厚的森林溪流资源，深度挖掘边境朝鲜族文化。
                                </p>
                                <button onClick={() => setInfoModalOpen(false)} className="w-full bg-gray-100 text-gray-800 py-3 rounded-xl font-bold mt-4">关闭</button>
                            </div>
                        </div>
                    )}

                    {/* AI Avatar Modal */}
                    {isAIAvatarModalOpen && (
                        <div className="fixed inset-0 z-[120] flex items-center justify-center p-4">
                            <div className="absolute inset-0 bg-black/80 backdrop-blur-sm" onClick={() => { if(!isGenerating) setAIAvatarModalOpen(false) }}></div>
                            <div className="bg-white rounded-3xl w-full max-w-3xl relative z-10 shadow-2xl overflow-hidden animate-slideUp">
                                <div className="bg-gradient-to-r from-indigo-900 via-purple-900 to-emerald-900 px-6 py-5 flex justify-between items-center text-white">
                                    <h3 className="text-xl font-bold flex items-center gap-2"><Icon name="Wand2" size={20} className="text-purple-300" /> AI 换装体验 (DeepSeek)</h3>
                                    {!isGenerating && <button onClick={() => { setAIAvatarModalOpen(false); resetAI(); }} className="hover:bg-white/20 p-1 rounded-full"><Icon name="X" size={24} /></button>}
                                </div>
                                <div className="p-6 md:p-8 bg-gray-50 min-h-[450px] flex flex-col items-center justify-center">
                                    {!uploadedImage ? (
                                        <label className="flex flex-col items-center justify-center w-full max-w-md h-72 border-2 border-dashed border-purple-300 rounded-3xl cursor-pointer bg-white hover:bg-purple-50 transition-colors shadow-sm">
                                            <div className="text-purple-600 mb-4"><Icon name="Camera" size={40} /></div>
                                            <p className="text-xl font-bold">点击上传正面照片</p>
                                            <input type="file" className="hidden" accept="image/*" onChange={handleImageUpload} />
                                        </label>
                                    ) : isGenerating ? (
                                        <div className="text-center">
                                            <div className="w-32 h-32 border-4 border-purple-100 border-t-purple-600 rounded-full animate-spin mx-auto mb-6"></div>
                                            <h4 className="text-2xl font-bold text-gray-800">DeepSeek 视觉大模型处理中...</h4>
                                        </div>
                                    ) : generatedImage ? (
                                        <div className="w-full">
                                            <div className="grid grid-cols-2 gap-4 md:gap-8 mb-8">
                                                <div>
                                                    <span className="block mb-2 font-bold text-center">原图</span>
                                                    <img src={uploadedImage} alt="Original" className="w-full h-48 md:h-64 object-cover rounded-2xl filter blur-[2px]" />
                                                </div>
                                                <div>
                                                    <span className="block mb-2 font-bold text-center text-purple-600">DeepSeek 生成结果</span>
                                                    <img src={generatedImage} alt="Generated" className="w-full h-48 md:h-64 object-cover rounded-2xl shadow-lg border-4 border-purple-200" />
                                                </div>
                                            </div>
                                            <div className="flex justify-center gap-4">
                                                <button onClick={resetAI} className="px-8 py-3 border border-gray-300 rounded-full bg-white">重试</button>
                                                <button onClick={() => showToast('已保存！')} className="px-8 py-3 bg-purple-600 text-white rounded-full font-bold">下载保存</button>
                                            </div>
                                        </div>
                                    ) : (
                                        <div className="text-center">
                                            <img src={uploadedImage} alt="Preview" className="w-48 h-48 rounded-full object-cover mx-auto mb-6 border-4 border-white shadow-xl" />
                                            <div className="flex gap-4 justify-center">
                                                <button onClick={() => setUploadedImage(null)} className="px-8 py-3 border border-gray-300 rounded-full bg-white">重选</button>
                                                <button onClick={handleGenerateAI} className="px-8 py-3 bg-emerald-600 text-white rounded-full font-bold flex items-center gap-2"><Icon name="Wand2" size={18}/> 开始 AI 换装</button>
                                            </div>
                                        </div>
                                    )}
                                </div>
                            </div>
                        </div>
                    )}

                    {/* Floating AI Button */}
                    <button onClick={() => setAIAvatarModalOpen(true)} className="fixed bottom-8 right-8 z-[90] bg-gradient-to-r from-purple-600 to-indigo-600 text-white p-4 md:p-5 rounded-full shadow-2xl hover:scale-110 transition-transform flex items-center justify-center">
                        <Icon name="Wand2" size={28} />
                    </button>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
