          /* --- DETAIL VIEW --- */
          <div className="pt-8">
            <div className="mb-16 border-b border-slate-200 pb-8 flex items-end gap-6">
               <div className="bg-slate-800 w-16 h-16 rounded-2xl flex items-center justify-center shadow-lg shadow-slate-900/10">
                 {currentCategory && <currentCategory.icon className="text-white w-8 h-8" />}
               </div>
               <div>
                 <h2 className="text-4xl font-extrabold text-slate-800">{currentCategory?.name} <span className="text-slate-300 font-normal">|</span> <span className="text-2xl text-slate-500 font-medium">{currentCategory?.subtitle}</span></h2>
               </div>
            </div>
            
            <div className="min-h-[50vh]">
              {currentCategory?.component}
            </div>
          </div>
        )}
      </main>

      {/* Minimalist Footer */}
      <footer className="w-full py-8 text-center text-xs font-medium text-slate-400 tracking-wider">
        © {new Date().getFullYear()} 琵岩山文旅产品方案. ALL RIGHTS RESERVED.
      </footer>
    </div>
  );
}
